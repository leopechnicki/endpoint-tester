{
  "name": "endpoint-tester",
  "version": "0.3.0",
  "description": "Auto-discover API endpoints and generate comprehensive test suites",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "endpoint-tester": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src/",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "commander": "^14.0.0",
    "glob": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^2.0.0"
  },
  "license": "MIT",
  "keywords": [
    "api",
    "testing",
    "endpoint",
    "test-generation",
    "express",
    "fastapi",
    "spring",
    "cli",
    "automation"
  ],
  "author": "Leonardo Pechnicki <leopsantos@hotmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leopechnicki/endpoint-tester.git"
  },
  "homepage": "https://github.com/leopechnicki/endpoint-tester#readme",
  "bugs": {
    "url": "https://github.com/leopechnicki/endpoint-tester/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  }
}
